[Unit]
Description=Clipship receiver
After=network.target

[Service]
User=www-data
WorkingDirectory=/opt/clipship/server
ExecStart=/opt/clipship/server/venv/bin/python receiver.py
Restart=on-failure
RestartSec=5

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
# Allow writes only to the inbox directory; adjust to match OUTPUT_DIR in config.py.
ReadWritePaths=/var/lib/clipship/inbox

[Install]
WantedBy=multi-user.target
