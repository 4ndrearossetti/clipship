# Clipship server configuration.
# Copy this file to config.py and fill in real values.
#
# Generate a strong SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY = "replace-with-token_hex(32)-output"

# Absolute path to the directory where clipped Markdown files will be written.
# Must exist and be writable by the user that runs the receiver.
OUTPUT_DIR = "/path/to/your/inbox"

# Bind address. Keep this on localhost and put Nginx/Caddy in front for TLS.
HOST = "127.0.0.1"
PORT = 5050

# Maximum accepted clock skew between extension and server, in seconds.
MAX_CLOCK_SKEW = 300

# Maximum request body size, in bytes (default 10 MiB).
MAX_BODY_BYTES = 10 * 1024 * 1024

# --- Asset localization -----------------------------------------------------
# When True, the server downloads every image referenced in the clipped
# markdown, stores it under OUTPUT_DIR/<ASSETS_SUBDIR>, and rewrites the
# markdown to point at the local copy. Set to False if you want clips to
# keep referencing the original remote URLs.
DOWNLOAD_ASSETS = True

# Subdirectory inside OUTPUT_DIR where downloaded assets are written. One
# folder for all clips; the per-file slug prefix keeps names unique.
ASSETS_SUBDIR = "assets"

# Per-asset size cap, in bytes. Anything larger is skipped.
MAX_ASSET_BYTES = 25 * 1024 * 1024

# Hard cap on the number of assets fetched per clip.
MAX_ASSETS_PER_CLIP = 100

# Per-asset network timeout, in seconds.
ASSET_TIMEOUT = 10

# User-Agent the server uses when fetching assets.
ASSET_USER_AGENT = "Clipship/1.0 (+https://github.com/4ndrearossetti/clipship)"

# --- PDF clipping -----------------------------------------------------------
# When True, clipping a tab whose URL ends in .pdf causes the server to
# download the PDF, store it under <ASSETS_SUBDIR>, and write a stub Markdown
# file with frontmatter + link + (optionally) extracted text.
DOWNLOAD_PDFS = True

# Per-PDF size cap, in bytes (default 100 MiB; bigger than images).
MAX_PDF_BYTES = 100 * 1024 * 1024

# Per-PDF network timeout, in seconds.
PDF_TIMEOUT = 30

# When True, the server tries to extract text from the PDF and embed it in
# the Markdown file (requires the `pypdf` package; gracefully no-ops if not
# installed). Set to False if you only want the PDF stored and linked.
EXTRACT_PDF_TEXT = True

# --- Web UI -----------------------------------------------------------------
# Browse clipped Markdown files from a web browser. Run via:
#   python web.py        (or the `clipship-web` systemd unit)
# Disabled by default so receiver-only deployments are unaffected.
WEB_UI_ENABLED = False
WEB_UI_USERNAME = "admin"
WEB_UI_PASSWORD = ""         # set this before enabling
WEB_UI_HOST = "127.0.0.1"    # put Nginx in front for TLS
WEB_UI_PORT = 5051
WEB_UI_PAGE_SIZE = 30
